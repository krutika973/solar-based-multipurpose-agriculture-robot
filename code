Programming:
cpp
#include <Servo.h>
Servo seedServo;
void setup() {
seedServo.attach(D11); // Attach to PWM pin
seedServo.write(0); // Initial position: retracted }
void positionServo(int relayValue) { if(relayValue == 3) {
seedServo.write(90); // Seeding position }else {
seedServo.write(0); // Retracted position }
}
